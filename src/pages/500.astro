---
import Default from '../layouts/default.astro';

interface Props {
  error: unknown;
}

const { error } = Astro.props;
---
<div>{error instanceof Error ? error.message : "Unknown error"}</div>
<Default title="500">
  <div class="wiggle woosh flash error-content">
    <div class="error-code rainbow-fast">500</div>
    <div class="error-message">{ error instanceof Error ? error.message : "Unknown error" }</div>
  </div>
</Default>
<style scoped>
  .error-content {
    text-align: center;
    padding: 9rem 12px;
  }
  .error-code {
    font-size: min(15dvw, 8rem);
    padding: 8px;
    padding-bottom: 0;
    font-weight: bolder;
  }
  .error-message {
    margin: 2px;
  }
</style>